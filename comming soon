<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            margin: 0;
            overflow: hidden;
        }

        #gif-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1;
        }

        #gif-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        #music-player {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
        }
    </style>
    <title>COMMMING SOON | rgbibelofficial.de </title>
</head>
<body>
    <div id="gif-container">
        <!-- Replace 'RGBIBEL-OFFICIAL-_1_gif.gif' with the path to your GIF -->
        <img src="RGBIBEL OFFICIAL.gif" alt="Fullscreen GIF">
    </div>

    <div id="music-player">
        <!-- Replace 'your-audio-file.mp3' with the path to your MP3 file -->
        <audio autoplay>
            <source src="ss.wav" type="audio/wav">
            Your browser does not support the audio tag.
        </audio>
    </div>
</body>
</html>
